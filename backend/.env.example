PORT=8087
NODE_ENV=development

# Database (seed sırasında DROP/CREATE yetkisi gerekir — root veya yetkili user kullan)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ensotek_com_tr_db
DB_USER=root
DB_PASSWORD=

# Auth
JWT_SECRET=change-me-jwt-ensotek-com-tr
COOKIE_SECRET=change-me-cookie-ensotek-com-tr

# CORS (virgülle ayrılmış origin listesi)
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Admin seed
ADMIN_EMAIL=admin@ensotek.com.tr
ADMIN_ID=ens0tr01-0000-0000-0000-000000000001
ADMIN_PASSWORD=admin123

# Site settings key prefix
SITE_SETTINGS_KEY_PREFIX=ensotek_com_tr__

# Storage
STORAGE_DRIVER=cloudinary
LOCAL_STORAGE_ROOT=
LOCAL_STORAGE_BASE_URL=/uploads

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=ensotek-com-tr
CLOUDINARY_BASE_PUBLIC=

# Mail / SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Telegram (opsiyonel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI (opsiyonel)
AI_SUPPORT_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Audit
AUDIT_EXCLUDE_IPS=127.0.0.1,::1

# Sentry (opsiyonel)
SENTRY_DSN=

# i18n
APP_LOCALES=tr,en,de
DEFAULT_LOCALE=tr
