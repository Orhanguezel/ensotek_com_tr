{
  "name": "ensotek-com-tr-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json; bun x tsc-alias -p tsconfig.json && node scripts/fix-esm-extensions.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "db:seed": "bun src/db/seed/index.ts",
    "db:seed:nodrop": "bun src/db/seed/index.ts --no-drop",
    "db:seed:only": "bun src/db/seed/index.ts --only="
  },
  "dependencies": {
    "@ensotek/shared-backend": "workspace:*",
    "@ensotek/shared-types": "workspace:*",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "2.0.0",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.0",
    "uuid": "^11.1.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.5.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5"
  },
  "overrides": {
    "zod-to-json-schema": "3.23.2"
  },
  "resolutions": {
    "zod-to-json-schema": "3.23.2"
  }
}
